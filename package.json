{
  "name": "tradjs",
  "version": "2.5.8",
  "description": "A Next.js-inspired Bun framework with file-based routing, server-rendered JSX, and a flexible client runtime.",
  "module": "./src/web.ts",
  "main": "./src/web.ts",
  "bin": {
    "tradjs": "./bin/melina.ts",
    "fastjs": "./bin/melina.ts",
    "lastjs": "./bin/melina.ts",
    "melina": "./bin/melina.ts"
  },
  "files": [
    "src",
    "bin",
    "docs",
    "README.md",
    "SKILL.md",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/web.d.ts",
      "default": "./src/web.ts"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "default": "./src/web.ts"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./src/server/index.ts"
    },
    "./server/build": {
      "types": "./dist/server/build.d.ts",
      "default": "./src/server/build.ts"
    },
    "./server/serve": {
      "types": "./dist/server/serve.d.ts",
      "default": "./src/server/serve.ts"
    },
    "./server/imports": {
      "types": "./dist/server/imports.d.ts",
      "default": "./src/server/imports.ts"
    },
    "./server/router": {
      "types": "./dist/server/router.d.ts",
      "default": "./src/server/router.ts"
    },
    "./server/ssr": {
      "types": "./dist/server/ssr.d.ts",
      "default": "./src/server/ssr.ts"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./src/client/index.ts"
    },
    "./client/render": {
      "types": "./dist/client/render.d.ts",
      "default": "./src/client/render.ts"
    },
    "./client/types": {
      "types": "./dist/client/types.d.ts",
      "default": "./src/client/types.ts"
    },
    "./client/reconcilers": {
      "types": "./dist/client/reconcilers/index.d.ts",
      "default": "./src/client/reconcilers/index.ts"
    },
    "./client/jsx-runtime": {
      "types": "./dist/client/jsx-runtime.d.ts",
      "default": "./src/client/jsx-runtime.ts"
    },
    "./client/jsx-dev-runtime": {
      "types": "./dist/client/jsx-dev-runtime.d.ts",
      "default": "./src/client/jsx-dev-runtime.ts"
    },
    "./client/jsx-dom": {
      "types": "./dist/client/jsx-dom.d.ts",
      "default": "./src/client/jsx-dom.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/7flash/melina.js"
  },
  "author": {
    "name": "TradJS Contributors"
  },
  "bugs": "https://github.com/7flash/melina.js/issues",
  "homepage": "https://github.com/7flash/melina.js#readme",
  "license": "MIT",
  "keywords": [
    "bun",
    "server",
    "framework",
    "typescript",
    "web",
    "ssr",
    "jsx",
    "app-router",
    "view-transitions",
    "tradjs"
  ],
  "type": "module",
  "private": false,
  "sideEffects": false,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsdom": "^28.0.0",
    "jsdom": "^28.1.0",
    "tradjs": "link:."
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "measure-fn": "3.10.1",
    "postcss": "^8.5.6",
    "ts-dedent": "^2.2.0"
  },
  "types": "./dist/web.d.ts",
  "scripts": {
    "prebuild": "npx -y rimraf dist",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  }
}
